#!/bin/bash
# no-OS pre-commit hook
# Runs code quality checks before allowing commits

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# Load configuration
CONFIG_FILE="$REPO_ROOT/.pre-commit-config"
if [ -f "$CONFIG_FILE" ]; then
    source "$CONFIG_FILE"
fi

# Default configuration
ENABLE_ASTYLE=${ENABLE_ASTYLE:-true}
ENABLE_CPPCHECK=${ENABLE_CPPCHECK:-true}
ENABLE_BUILD_CHECK=${ENABLE_BUILD_CHECK:-false}  # Disabled by default (can be slow)
ENABLE_DOC_CHECK=${ENABLE_DOC_CHECK:-true}
ENABLE_REVIEW_CHECK=${ENABLE_REVIEW_CHECK:-true}
ENABLE_BRANCH_CHECK=${ENABLE_BRANCH_CHECK:-true}

# Helper functions
echo_info() {
    echo -e "${BLUE}ℹ️  $1${NC}"
}

echo_success() {
    echo -e "${GREEN}✅ $1${NC}"
}

echo_warning() {
    echo -e "${YELLOW}⚠️  $1${NC}"
}

echo_error() {
    echo -e "${RED}❌ $1${NC}"
}

# Get list of staged files
get_staged_files() {
    git diff --cached --name-only --diff-filter=d
}

get_staged_c_files() {
    get_staged_files | grep -E '\.(c|h)$' || true
}

get_staged_projects() {
    get_staged_files | grep '^projects/' | cut -d'/' -f2 | sort -u || true
}

# Check if AStyle is available
check_astyle() {
    if [ "$ENABLE_ASTYLE" != "true" ]; then
        return 0
    fi

    echo_info "Checking code style (AStyle)..."

    # Build AStyle if not available
    if [ ! -f "build/astyle/build/gcc/bin/astyle" ]; then
        echo_warning "AStyle not found, building..."
        ./ci/astyle.sh HEAD~1 > /dev/null 2>&1 || {
            echo_error "Failed to build AStyle"
            return 1
        }
    fi

    local c_files=$(get_staged_c_files)
    if [ -z "$c_files" ]; then
        echo_success "No C/C++ files to check"
        return 0
    fi

    # Check each staged C/C++ file
    local style_issues=false
    local style_files=()

    for file in $c_files; do
        if [ -f "$file" ]; then
            # Create a temporary copy to test formatting
            cp "$file" "$file.tmp"
            ./build/astyle/build/gcc/bin/astyle --options=ci/astyle_config "$file.tmp" > /dev/null 2>&1

            if ! cmp -s "$file" "$file.tmp"; then
                style_issues=true
                style_files+=("$file")

                # Show what would change
                echo ""
                echo_error "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                echo_error "Code style issues in: $file"
                echo_error "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                echo ""
                echo_info "Differences (current vs. formatted):"
                diff -u "$file" "$file.tmp" | head -100 | sed 's/^/  /' || true
                echo ""
                echo_info "Common style issues:"
                echo_info "  • Indentation: Use tabs (not spaces)"
                echo_info "  • Braces: Opening brace on same line for functions"
                echo_info "  • Spacing: Space after keywords (if, for, while, switch)"
                echo_info "  • Operators: Spaces around binary operators (=, +, -, etc.)"
                echo ""
            fi
            rm -f "$file.tmp"
        fi
    done

    if [ "$style_issues" = "true" ]; then
        echo ""
        echo_error "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo_error "ASTYLE CODE FORMATTING REQUIRED"
        echo_error "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo ""
        echo_info "🔧 To automatically fix all style issues:"
        echo ""
        for file in "${style_files[@]}"; do
            echo_info "  ./build/astyle/build/gcc/bin/astyle --options=ci/astyle_config $file"
        done
        echo ""
        echo_info "Or fix all staged files at once:"
        echo_info "  git diff --cached --name-only | grep -E '\.(c|h)$' | xargs -I {} ./build/astyle/build/gcc/bin/astyle --options=ci/astyle_config {}"
        echo ""
        echo_info "After formatting, stage the changes:"
        echo_info "  git add ${style_files[*]}"
        echo ""
        return 1
    fi

    echo_success "Code style check passed"
    return 0
}

# Check with Cppcheck
check_cppcheck() {
    if [ "$ENABLE_CPPCHECK" != "true" ]; then
        return 0
    fi

    echo_info "Running static analysis (Cppcheck)..."

    # Check if cppcheck is installed
    if ! command -v cppcheck > /dev/null 2>&1; then
        echo_warning "Cppcheck not found, skipping static analysis"
        return 0
    fi

    local c_files=$(get_staged_c_files)
    if [ -z "$c_files" ]; then
        echo_success "No C/C++ files to analyze"
        return 0
    fi

    # Run cppcheck on staged files only (verbose output)
    local cppcheck_opts="--force --error-exitcode=1 --enable=warning,style,performance --template=gcc"

    if [ -f ".cppcheckignore" ]; then
        cppcheck_opts="$cppcheck_opts --suppressions-list=.cppcheckignore"
    fi

    # Add Claude-specific suppressions if file exists
    if [ -f ".claude/.cppcheckignore" ]; then
        cppcheck_opts="$cppcheck_opts --suppressions-list=.claude/.cppcheckignore"
    fi

    if [ -f "./ci/config.cppcheck" ]; then
        cppcheck_opts="$cppcheck_opts --library=./ci/config.cppcheck"
    fi

    # Capture cppcheck output
    local cppcheck_output=$(mktemp)
    echo "$c_files" | xargs cppcheck $cppcheck_opts 2>&1 | tee "$cppcheck_output"
    local cppcheck_exit=${PIPESTATUS[1]}  # Get exit code of cppcheck (second command in pipe)

    if [ $cppcheck_exit -eq 0 ]; then
        rm -f "$cppcheck_output"
        echo_success "Static analysis passed"
        return 0
    else
        echo ""
        echo_error "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo_error "CPPCHECK STATIC ANALYSIS FINDINGS"
        echo_error "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo ""

        # Parse and categorize errors with helpful suggestions
        while IFS= read -r line; do
            if [[ "$line" =~ ":" ]]; then
                echo_error "$line"

                # Provide correction hints based on common error patterns
                if [[ "$line" =~ "unusedVariable" ]] || [[ "$line" =~ "unreadVariable" ]]; then
                    echo_info "  💡 Fix: Remove unused variable or mark as unused with (void)variable_name;"
                elif [[ "$line" =~ "uninitvar" ]]; then
                    echo_info "  💡 Fix: Initialize variable before use (e.g., int var = 0;)"
                elif [[ "$line" =~ "nullPointer" ]]; then
                    echo_info "  💡 Fix: Add NULL check before dereferencing pointer"
                elif [[ "$line" =~ "memleak" ]]; then
                    echo_info "  💡 Fix: Ensure free()/no_os_free() is called for all allocated memory"
                elif [[ "$line" =~ "resourceLeak" ]]; then
                    echo_info "  💡 Fix: Close file/resource handles in all code paths (including error paths)"
                elif [[ "$line" =~ "arrayIndexOutOfBounds" ]]; then
                    echo_info "  💡 Fix: Verify array index is within bounds (0 to size-1)"
                elif [[ "$line" =~ "bufferAccessOutOfBounds" ]]; then
                    echo_info "  💡 Fix: Check buffer size before access; ensure index < buffer_size"
                elif [[ "$line" =~ "uninitStructMember" ]]; then
                    echo_info "  💡 Fix: Initialize all struct members or use memset() to zero"
                elif [[ "$line" =~ "invalidPrintfArgType" ]]; then
                    echo_info "  💡 Fix: Use correct format specifier (%d for int, %u for unsigned, %p for pointer)"
                elif [[ "$line" =~ "missingReturn" ]]; then
                    echo_info "  💡 Fix: Add return statement with appropriate value"
                elif [[ "$line" =~ "variableScope" ]]; then
                    echo_info "  💡 Fix: Move variable declaration to innermost scope where it's used"
                elif [[ "$line" =~ "constParameter" ]]; then
                    echo_info "  💡 Fix: Add 'const' qualifier to parameter that isn't modified"
                elif [[ "$line" =~ "shadowVariable" ]]; then
                    echo_info "  💡 Fix: Rename local variable to avoid shadowing outer scope variable"
                fi
                echo ""
            fi
        done < "$cppcheck_output"

        rm -f "$cppcheck_output"

        echo_error "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo_info "📖 Common Cppcheck Error References:"
        echo_info "  • unusedVariable/unreadVariable: Variable declared but never read"
        echo_info "  • uninitvar: Variable used before initialization"
        echo_info "  • nullPointer: Potential NULL pointer dereference"
        echo_info "  • memleak: Allocated memory not freed"
        echo_info "  • resourceLeak: File/resource handle not closed"
        echo ""
        echo_info "To suppress false positives, add to .cppcheckignore:"
        echo_info "  *:file.c:123  (suppress all errors on line 123 of file.c)"
        echo_info "  errorType:file.c:123  (suppress specific error type)"
        echo ""
        return 1
    fi
}

# Check documentation
check_documentation() {
    if [ "$ENABLE_DOC_CHECK" != "true" ]; then
        return 0
    fi

    echo_info "Checking documentation..."

    local doc_issues=false
    local c_files=$(get_staged_c_files)
    local has_warnings=false

    for file in $c_files; do
        if [[ "$file" == *.h ]] && [ -f "$file" ]; then
            # Check for proper header guard
            local guard_name=$(basename "$file" | tr '[:lower:]' '[:upper:]' | sed 's/\./_/g')
            local expected_guard="__${guard_name}__"

            if ! grep -q "#ifndef $expected_guard" "$file" || ! grep -q "#define $expected_guard" "$file"; then
                if [ "$has_warnings" = "false" ]; then
                    echo ""
                    echo_warning "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                    echo_warning "DOCUMENTATION WARNINGS"
                    echo_warning "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                    has_warnings=true
                fi
                echo ""
                echo_warning "Header guard format issue in: $file"
                echo_info "  Expected format:"
                echo_info "    #ifndef $expected_guard"
                echo_info "    #define $expected_guard"
                echo_info "    ... (header content) ..."
                echo_info "    #endif // $expected_guard"
                echo ""
            fi

            # Check for basic Doxygen documentation on public functions
            if grep -q "^int.*(" "$file" && ! grep -q "@brief\|@param\|@return" "$file"; then
                if [ "$has_warnings" = "false" ]; then
                    echo ""
                    echo_warning "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                    echo_warning "DOCUMENTATION WARNINGS"
                    echo_warning "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
                    has_warnings=true
                fi
                echo ""
                echo_warning "Missing Doxygen documentation in: $file"
                echo_info "  Add documentation for public functions:"
                echo_info "    /**"
                echo_info "     * @brief Brief description of function"
                echo_info "     * @param param_name - Description of parameter"
                echo_info "     * @return Description of return value"
                echo_info "     */"
                echo_info "    int function_name(type param_name);"
                echo ""
            fi
        fi
    done

    if [ "$has_warnings" = "true" ]; then
        echo ""
        echo_info "📖 Documentation best practices:"
        echo_info "  • Use Doxygen-style comments (/** ... */)"
        echo_info "  • Document all public APIs (@brief, @param, @return)"
        echo_info "  • Use proper header guards in all .h files"
        echo_info "  • These are warnings only - commit will proceed"
        echo ""
    fi

    echo_success "Documentation check completed"
    return 0
}

# Run build validation
check_build() {
    if [ "$ENABLE_BUILD_CHECK" != "true" ]; then
        return 0
    fi

    echo_info "Running build validation..."

    local projects=$(get_staged_projects)
    if [ -z "$projects" ]; then
        echo_success "No project changes to build"
        return 0
    fi

    # Test build for each affected project
    for project in $projects; do
        if [ -f "projects/$project/Makefile" ]; then
            echo_info "Building project: $project"
            if ! python3 tools/scripts/build_projects.py . -project="$project" > /dev/null 2>&1; then
                echo_error "Build failed for project: $project"
                return 1
            fi
        fi
    done

    echo_success "Build validation passed"
    return 0
}

# Run automated review checks
check_review_patterns() {
    if [ "$ENABLE_REVIEW_CHECK" != "true" ]; then
        return 0
    fi

    echo_info "Running automated review checks..."

    if [ -f ".claude/tools/pre-commit/review-checker.py" ]; then
        local c_files=$(get_staged_c_files)
        if [ -n "$c_files" ]; then
            if echo "$c_files" | xargs python3 .claude/tools/pre-commit/review-checker.py; then
                echo_success "Review checks passed"
            else
                echo_warning "Review checker found potential issues"
                echo_info "These are suggestions - review and fix if needed"
                # Don't fail the commit for review suggestions
            fi
        fi
    else
        echo_warning "Review checker not found, skipping"
    fi

    return 0
}

# Check branch naming convention
check_branch_name() {
    if [ "$ENABLE_BRANCH_CHECK" != "true" ]; then
        return 0
    fi

    echo_info "Checking branch naming convention..."

    if [ -f ".claude/tools/pre-commit/check-branch-name.sh" ]; then
        if bash .claude/tools/pre-commit/check-branch-name.sh; then
            return 0
        else
            return 1
        fi
    else
        echo_warning "Branch name checker not found, skipping"
        return 0
    fi
}

# Main execution
main() {
    echo_info "🔍 Running no-OS pre-commit checks..."
    echo ""

    local exit_code=0

    # Only run checks if there are staged files
    local staged_files=$(get_staged_files)
    if [ -z "$staged_files" ]; then
        echo_warning "No staged files found"
        exit 0
    fi

    # Run all checks
    check_branch_name || exit_code=1
    check_astyle || exit_code=1
    check_cppcheck || exit_code=1
    check_documentation || exit_code=1
    check_review_patterns || true  # Don't fail on review suggestions
    check_build || exit_code=1

    echo ""
    if [ $exit_code -eq 0 ]; then
        echo_success "🎉 All pre-commit checks passed!"
        echo_info "Commit can proceed"
    else
        echo_error "💥 Pre-commit checks failed!"
        echo_info "Fix the issues above and try again"
        echo_info "Use 'git commit --no-verify' to bypass checks if needed"
    fi

    exit $exit_code
}

main "$@"